# Copy this file to `.env.local` and fill in real values.
# Get Supabase values from: Supabase Dashboard → Project Settings → API / Database.
# `.env.local` is gitignored — never commit real secrets.

# ── Supabase ──
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=          # server-only secret (service_role or sb_secret_…)
SUPABASE_DB_PASSWORD=               # for migrations / Supabase CLI

# ── Razorpay (added later) ──
# RAZORPAY_KEY_ID=
# RAZORPAY_KEY_SECRET=
# RAZORPAY_WEBHOOK_SECRET=

# ── Resend / email (added later) ──
# RESEND_API_KEY=
# EMAIL_FROM=
# EMAIL_ADMIN=
