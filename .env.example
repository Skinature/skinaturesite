# Copy this file to `.env.local` and fill in real values.
# Get Supabase values from: Supabase Dashboard → Project Settings → API / Database.
# `.env.local` is gitignored — never commit real secrets.

# ── Supabase ──
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=          # server-only secret (service_role or sb_secret_…)
SUPABASE_DB_PASSWORD=               # for migrations / Supabase CLI

# ── Razorpay (test mode first; live keys only at launch) ──
# From Razorpay DESKTOP dashboard → Test Mode → Account & Settings → API Keys → Generate Key
# (the mobile app does not expose Test Mode). Test keys are in .env.local as of 2026-07-06.
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxx
RAZORPAY_KEY_SECRET=
# RAZORPAY_WEBHOOK_SECRET=          # set when the webhook is created at deploy

# ── Resend / email (added when the sending domain is verified) ──
# RESEND_API_KEY=
# EMAIL_FROM=Skinature <orders@skinature.org>
# EMAIL_ADMIN=admin@skinature.org

# ── Cron (review-invite auto-send) ──
# CRON_SECRET=                      # any long random string; used to authorize /api/cron/*

# ── Preview lock (optional) ──
# Set on a shared Vercel preview to password-protect the whole site + mark it noindex.
# Format is "user:password". Leave UNSET in production (then it's a no-op).
# PREVIEW_BASIC_AUTH=skinature:choose-a-password
